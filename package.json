{
  "name": "nijaworld-root",
  "version": "1.0.0",
  "description": "NijaWorld Website - Root Workspace",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" --names \"FRONTEND,BACKEND\" --prefix-colors \"cyan,green\"",
    "build": "cd frontend && npm run build",
    "seed": "cd backend && npm run seed"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
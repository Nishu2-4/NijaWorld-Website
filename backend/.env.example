MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1d
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── SMTP Email Configuration ───────────────────────────────────────────
# Fill in your SMTP provider credentials below.
# Common providers:
#   Gmail:       SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (use App Password)
#   Zoho:        SMTP_HOST=smtp.zoho.com   SMTP_PORT=587
#   Brevo:       SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587
#   Mailgun:     SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_app_password
EMAIL_FROM=reach@yourdomain.com
